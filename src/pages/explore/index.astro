---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { heresies } from '../../data/heresies';
import { councils } from '../../data/councils';

// Group heresies by category
const categories: Record<string, typeof heresies> = {};
for (const heresy of heresies) {
  // Determine display category from the heresy data
  const cat = getCategoryForHeresy(heresy.id);
  if (!categories[cat]) categories[cat] = [];
  categories[cat].push(heresy);
}

function getCategoryForHeresy(id: string): string {
  const map: Record<string, string> = {
    'arianism': 'Trinity',
    'modalism': 'Trinity',
    'subordinationism': 'Trinity',
    'homoianism': 'Trinity',
    'homoiousian': 'Trinity',
    'anomoeanism': 'Trinity',
    'nicene-trinitarianism': 'Trinity',
    'efs': 'Trinity',
    'docetism': 'Christology',
    'nestorianism': 'Christology',
    'eutychianism': 'Christology',
    'monothelitism': 'Christology',
    'adoptionism': 'Christology',
    'apollinarianism': 'Christology',
    'pelagianism': 'Soteriology',
    'semi-pelagianism': 'Soteriology',
    'universalism': 'Eschatology',
    'annihilationism': 'Eschatology',
    'premillennialism': 'Eschatology',
    'iconoclasm': 'Worship',
    'marcionism': 'Scripture',
    'sola-scriptura': 'Authority',
    'papal-infallibility': 'Authority',
    'montanism': 'Pneumatology',
    'cessationism': 'Pneumatology',
    'transubstantiation': 'Sacraments',
    'memorialism': 'Sacraments',
    'paedobaptism': 'Sacraments',
    'credobaptism': 'Sacraments',
  };
  return map[id] || 'Other';
}

const categoryOrder = ['Trinity', 'Christology', 'Soteriology', 'Eschatology', 'Sacraments', 'Authority', 'Pneumatology', 'Scripture', 'Worship', 'Other'];

const antiNiceneCouncils = councils
  .filter((c) => c.type === 'anti-nicene')
  .sort((a, b) => a.year - b.year);

const allCouncils = councils
  .filter((c) => c.type !== 'anti-nicene')
  .sort((a, b) => a.year - b.year);
---

<BaseLayout title="Explore Heresies — The Heresy Timeline" description="A timeline of the major heresies condemned by the Christian church — including the 20 years when the heretics won.">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <div class="text-center mb-12">
      <p class="text-xs font-semibold text-crimson uppercase tracking-widest mb-3">
        2,000 Years of Controversy
      </p>
      <h1 class="text-4xl md:text-5xl font-black text-charcoal mb-4" style="font-family: 'Playfair Display', Georgia, serif;">
        The Heresy Timeline
      </h1>
      <p class="text-lg text-charcoal/60 max-w-2xl mx-auto">
        Every heresy below was once someone's deeply held belief — and every condemnation reflects the consensus of a particular time and place. Explore them all.
      </p>
    </div>

    <!-- Heresies by Category -->
    {categoryOrder.filter(cat => categories[cat]?.length).map((cat) => (
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-charcoal mb-4" style="font-family: 'Playfair Display', Georgia, serif;">
          {cat}
        </h2>
        <div class="space-y-3">
          {categories[cat]
            .sort((a, b) => a.yearCondemned - b.yearCondemned)
            .map((heresy) => {
              const isAntiNicene = ['nicene-trinitarianism', 'homoianism', 'homoiousian', 'anomoeanism'].includes(heresy.id);
              return (
                <a
                  href={`/explore/${heresy.slug}`}
                  class:list={[
                    'block border rounded-xl p-5 hover:shadow-md transition-all group',
                    isAntiNicene ? 'bg-rose-50/50 border-rose-200 hover:border-rose-300' : 'bg-white border-charcoal/10 hover:border-gold',
                  ]}
                >
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <div class="flex items-center gap-2 mb-1">
                        <h3 class="text-lg font-bold text-charcoal group-hover:text-crimson transition-colors">
                          {heresy.name}
                        </h3>
                        {isAntiNicene && (
                          <span class="text-xs bg-rose-100 text-rose-700 px-2 py-0.5 rounded-full font-medium">
                            Contested
                          </span>
                        )}
                      </div>
                      <p class="text-charcoal/60 text-sm">{heresy.shortDescription}</p>
                    </div>
                    <span class:list={[
                      'text-xs font-bold px-2.5 py-1 rounded-full whitespace-nowrap',
                      isAntiNicene ? 'bg-rose-100 text-rose-700' : 'bg-crimson/10 text-crimson',
                    ]}>
                      {heresy.yearCondemned > 0 ? `${heresy.yearCondemned} AD` : 'Modern'}
                    </span>
                  </div>
                </a>
              );
            })}
        </div>
      </section>
    ))}

    <!-- Anti-Nicene Councils Section -->
    <section class="bg-rose-50 rounded-2xl border border-rose-200 p-8 mb-12">
      <h2 class="text-2xl font-bold mb-2 text-charcoal" style="font-family: 'Playfair Display', Georgia, serif;">
        The Anti-Nicene Councils (335&ndash;360 AD)
      </h2>
      <p class="text-charcoal/60 mb-6">
        Between Nicaea (325) and Constantinople (381), at least 13 councils rejected the Nicene formula.
        For twenty years, <em>homoousios</em> was the heretical position. These are the councils
        that history mostly forgot.
      </p>
      <div class="space-y-3">
        {antiNiceneCouncils.map((council) => (
          <div class="bg-white rounded-lg border border-rose-100 p-4">
            <div class="flex items-start justify-between gap-4">
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <h3 class="font-bold text-charcoal">{council.name}</h3>
                  {council.coerced && (
                    <span class="text-xs bg-crimson/10 text-crimson px-2 py-0.5 rounded-full font-medium">
                      Coerced
                    </span>
                  )}
                </div>
                <p class="text-charcoal/60 text-sm">{council.description}</p>
                {council.theologicalPosition && (
                  <p class="text-xs text-charcoal/40 mt-1">
                    Position: {council.theologicalPosition}
                    {council.imperialBacking && <> · Imperial backing: {council.imperialBacking}</>}
                  </p>
                )}
              </div>
              <span class="text-sm font-semibold text-rose-700 whitespace-nowrap">{council.year} AD</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- All Councils -->
    <section>
      <h2 class="text-2xl font-bold mb-6 text-charcoal" style="font-family: 'Playfair Display', Georgia, serif;">
        Ecumenical, Regional &amp; Confessional Councils
      </h2>
      <div class="space-y-3">
        {allCouncils.map((council) => (
          <div class="bg-white rounded-lg border border-charcoal/10 p-4">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="font-bold text-charcoal">{council.name}</h3>
                <p class="text-charcoal/60 text-sm">{council.description}</p>
              </div>
              <span class="text-xs font-bold bg-crimson/10 text-crimson px-2.5 py-1 rounded-full whitespace-nowrap">
                {council.year}{council.yearEnd ? `–${council.yearEnd}` : ''} AD
              </span>
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
