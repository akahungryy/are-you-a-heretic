---
import { getCollection, render } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';

export async function getStaticPaths() {
  const articleEntries = await getCollection('articles');
  return articleEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const allArticles = await getCollection('articles');
const relatedArticles = allArticles
  .filter((a) => a.id !== entry.id && a.data.category === entry.data.category)
  .slice(0, 3);

const heresyEntries = await getCollection('heresies');
const relatedHeresyPages = entry.data.relatedHeresies
  ? heresyEntries.filter((h) => entry.data.relatedHeresies!.includes(h.id))
  : [];

const publishDateFormatted = entry.data.publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<ContentLayout title={entry.data.title} description={entry.data.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Article',
      'headline': entry.data.title,
      'description': entry.data.description,
      'datePublished': entry.data.publishDate.toISOString(),
      'author': { '@type': 'Organization', 'name': 'Are You a Heretic?' },
      'publisher': { '@type': 'Organization', 'name': 'Are You a Heretic?' },
      'url': `https://areyouaheretic.com/articles/${entry.id}`,
    })} />
  </Fragment>

  <div class="mb-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="inline-block px-3 py-1 rounded-full text-xs font-medium bg-gold/10 text-gold-light capitalize">
        {entry.data.category}
      </span>
      <time class="text-sm text-charcoal/40" datetime={entry.data.publishDate.toISOString()}>
        {publishDateFormatted}
      </time>
    </div>
    <h1 class="text-4xl md:text-5xl font-black text-charcoal mb-4" style="font-family: 'Playfair Display', Georgia, serif;">
      {entry.data.title}
    </h1>
    {entry.data.subtitle && (
      <p class="text-xl text-charcoal/50" style="font-family: 'Crimson Text', Georgia, serif;">
        {entry.data.subtitle}
      </p>
    )}
  </div>

  <div class="prose-heresy">
    <Content />
  </div>

  {/* Quiz relation callout */}
  {entry.data.relatedQuestions && entry.data.relatedQuestions.length > 0 && (
    <div class="mt-10 p-6 bg-gold/10 border border-gold/20 rounded-xl">
      <p class="text-charcoal/80">
        This article relates to {entry.data.relatedQuestions.length > 1 ? 'Questions' : 'Question'}{' '}
        {entry.data.relatedQuestions.join(', ')} of the quiz.
      </p>
      <a href="/quiz" class="inline-block mt-3 text-crimson font-semibold hover:underline">
        Take the quiz and see what the councils say about your answer →
      </a>
    </div>
  )}

  {/* Quiz CTA */}
  <div class="mt-12 p-8 bg-charcoal text-parchment rounded-xl text-center">
    <p class="text-xl font-bold mb-2 text-gold" style="font-family: 'Playfair Display', Georgia, serif;">
      Curious where you'd land?
    </p>
    <p class="text-parchment/60 mb-6">Am I a heretic? Take the quiz and find out what the councils would say.</p>
    <a
      href="/quiz"
      class="inline-block px-8 py-3 bg-gold text-charcoal rounded-lg font-bold hover:bg-gold-light transition-colors"
    >
      Take the Quiz →
    </a>
  </div>

  {/* Related heresies */}
  {relatedHeresyPages.length > 0 && (
    <div class="mt-12">
      <h2 class="text-xl font-bold text-charcoal mb-4" style="font-family: 'Playfair Display', Georgia, serif;">
        Related Heresies
      </h2>
      <div class="grid gap-3">
        {relatedHeresyPages.map((heresy) => (
          <a
            href={`/explore/${heresy.id}`}
            class="flex items-start gap-3 p-4 bg-white border border-charcoal/10 rounded-lg hover:border-crimson/30 transition-colors group"
          >
            <span class="font-semibold text-charcoal group-hover:text-crimson transition-colors">
              {heresy.data.title}
            </span>
            <span class="text-charcoal/40 text-sm">— {heresy.data.shortDescription}</span>
          </a>
        ))}
      </div>
    </div>
  )}

  {/* Related articles */}
  {relatedArticles.length > 0 && (
    <div class="mt-12">
      <h2 class="text-xl font-bold text-charcoal mb-4" style="font-family: 'Playfair Display', Georgia, serif;">
        Related Articles
      </h2>
      <div class="grid gap-3">
        {relatedArticles.map((article) => (
          <a
            href={`/articles/${article.id}`}
            class="block p-4 bg-white border border-charcoal/10 rounded-lg hover:border-gold hover:shadow-sm transition-all group"
          >
            <span class="font-semibold text-charcoal group-hover:text-crimson transition-colors">
              {article.data.title}
            </span>
            <p class="text-charcoal/50 text-sm mt-1">{article.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  )}
</ContentLayout>
