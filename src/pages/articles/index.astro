---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const sortedArticles = allArticles.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

const categories = ['all', ...new Set(sortedArticles.map((a) => a.data.category))];
---

<BaseLayout
  title="Articles on Christian Heresies & Church History"
  description="Deep dives into Christian heresies, church councils, and the messy history of orthodoxy. From Arianism to universalism, explore 2000 years of theological controversy."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'CollectionPage',
      'name': 'Articles on Christian Heresies & Church History',
      'description': 'Deep dives into Christian heresies, church councils, and the messy history of orthodoxy.',
      'publisher': { '@type': 'Organization', 'name': 'Are You a Heretic?' },
    })} />
  </Fragment>

  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="text-center mb-12">
      <p class="text-xs font-semibold text-crimson uppercase tracking-widest mb-3">
        From the Archives
      </p>
      <h1 class="text-4xl md:text-5xl font-black text-charcoal mb-4" style="font-family: 'Playfair Display', Georgia, serif;">
        Articles
      </h1>
      <p class="text-lg text-charcoal/60 max-w-2xl mx-auto">
        Deep dives into Christian heresies, church councils, and the messy history of orthodoxy.
      </p>
    </div>

    <div class="flex gap-2 justify-center mb-10 flex-wrap">
      {categories.map((cat) => (
        <button
          class="category-filter px-4 py-1.5 rounded-full text-sm font-medium border transition-colors capitalize cursor-pointer"
          data-category={cat}
        >
          {cat}
        </button>
      ))}
    </div>

    <div class="grid md:grid-cols-2 gap-6" id="articles-grid">
      {sortedArticles.map((article) => (
        <a
          href={`/articles/${article.id}`}
          class="article-card block group"
          data-category={article.data.category}
        >
          <div class="bg-white rounded-xl border border-charcoal/10 p-6 h-full hover:border-gold hover:shadow-lg transition-all">
            <div class="flex items-center gap-3 mb-3">
              <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-gold/10 text-gold-light capitalize">
                {article.data.category}
              </span>
              <time class="text-xs text-charcoal/40" datetime={article.data.publishDate.toISOString()}>
                {article.data.publishDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
            </div>
            <h2 class="font-bold text-lg mb-2 text-charcoal group-hover:text-crimson transition-colors" style="font-family: 'Playfair Display', Georgia, serif;">
              {article.data.title}
            </h2>
            <p class="text-charcoal/60 text-sm line-clamp-3">{article.data.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .category-filter {
    background-color: white;
    color: var(--color-charcoal);
    border-color: rgba(26, 26, 46, 0.15);
  }
  .category-filter.active {
    background-color: var(--color-charcoal);
    color: var(--color-parchment);
    border-color: var(--color-charcoal);
  }
</style>

<script>
  const buttons = document.querySelectorAll('.category-filter');
  const cards = document.querySelectorAll('.article-card');

  buttons[0]?.classList.add('active');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      buttons.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      const cat = btn.getAttribute('data-category');
      cards.forEach((card) => {
        if (cat === 'all' || card.getAttribute('data-category') === cat) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
