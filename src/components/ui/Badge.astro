---
interface Props {
  severity?: 'condemned' | 'suspicious' | 'technically-orthodox-but';
  class?: string;
}

const { severity = 'condemned', class: className = '' } = Astro.props;

const severityClasses = {
  condemned: 'bg-red-100 text-red-800 border-red-200',
  suspicious: 'bg-amber-100 text-amber-800 border-amber-200',
  'technically-orthodox-but': 'bg-blue-100 text-blue-800 border-blue-200',
};

const classes = `inline-flex items-center px-3 py-1 rounded-full text-xs font-medium border ${severityClasses[severity]} ${className}`;
---

<span class={classes}>
  <slot />
</span>
