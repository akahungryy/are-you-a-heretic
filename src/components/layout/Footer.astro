---
import HereticTick from '../ui/HereticTick.astro';
---

<footer class="border-t border-charcoal/10 bg-charcoal text-parchment/60 py-12 mt-auto">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="text-center md:text-left">
        <p class="font-semibold text-parchment/80 font-display">
          Are You a Heretic?<HereticTick size="sm" />
        </p>
        <p class="text-sm mt-1 font-content">Built with historical sass and intellectual humility.</p>
      </div>
      <nav class="flex gap-6 text-sm">
        <a href="/quiz" class="hover:text-gold hover:underline underline-offset-4 transition-colors">Quiz</a>
        <a href="/explore" class="hover:text-gold hover:underline underline-offset-4 transition-colors">Explore</a>
        <a href="/articles" class="hover:text-gold hover:underline underline-offset-4 transition-colors">Articles</a>
        <a href="/about" class="hover:text-gold hover:underline underline-offset-4 transition-colors">About</a>
        <a href="/contact" class="hover:text-gold hover:underline underline-offset-4 transition-colors">Contact</a>
        <a href="/privacy" class="hover:text-gold hover:underline underline-offset-4 transition-colors">Privacy</a>
        <a href="/terms" class="hover:text-gold hover:underline underline-offset-4 transition-colors">Terms</a>
      </nav>
    </div>
    <div class="mt-6 pt-6 border-t border-parchment/10 text-center">
      <p class="text-xs text-parchment/50 mb-3">No actual anathemas were issued in the making of this quiz.</p>
      <a href="https://ko-fi.com/probablytheology" target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-1.5 text-xs text-parchment/50 hover:text-gold transition-colors mb-3">
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 8h1a4 4 0 010 8h-1"/>
          <path d="M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/>
          <line x1="6" y1="1" x2="6" y2="4"/>
          <line x1="10" y1="1" x2="10" y2="4"/>
          <line x1="14" y1="1" x2="14" y2="4"/>
        </svg>
        Buy me a coffee
      </a>
      <a href="mailto:openscriptureapp@gmail.com?subject=Feedback%20—%20Are%20You%20a%20Heretic%3F"
         class="inline-flex items-center gap-1.5 text-xs text-parchment/50 hover:text-gold transition-colors mb-3 ml-4">
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect width="20" height="16" x="2" y="4" rx="2" />
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
        </svg>
        Send Feedback
      </a>
      <p class="text-xs text-parchment/40">A site by Probably Theology — check out my other projects:
        <a href="https://probablytheology.com" target="_blank" rel="noopener noreferrer" class="text-gold/60 hover:text-gold transition-colors underline underline-offset-2 ml-2">Probably Theology</a>
        <span class="mx-1">·</span>
        <a href="https://christosproject.com" target="_blank" rel="noopener noreferrer" class="text-gold/60 hover:text-gold transition-colors underline underline-offset-2">Christos</a>
        <span class="mx-1">·</span>
        <a href="https://openscripture.io" target="_blank" rel="noopener noreferrer" class="text-gold/60 hover:text-gold transition-colors underline underline-offset-2">OpenScripture</a>
      </p>
    </div>
  </div>
</footer>
