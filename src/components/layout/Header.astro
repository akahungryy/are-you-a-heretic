---
import HereticTick from '../ui/HereticTick.astro';

const pathname = Astro.url.pathname;

const navItems = [
  { href: '/quiz', label: 'Quiz' },
  { href: '/explore', label: 'Explore' },
  { href: '/articles', label: 'Articles' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="sticky top-0 z-50 border-b border-charcoal/10 bg-parchment/90 backdrop-blur-md" data-pagefind-ignore="all">
  <nav class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
    <a
      href="/"
      class="text-xl font-bold text-charcoal hover:text-crimson transition-colors font-display tracking-tight"
    >
      Are You a Heretic?<HereticTick size="sm" />
    </a>
    <div class="hidden sm:flex items-center gap-6 text-sm font-medium">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'transition-colors hover:underline underline-offset-4 decoration-2 decoration-crimson',
            pathname.startsWith(item.href)
              ? 'text-crimson font-semibold'
              : 'text-charcoal/70 hover:text-crimson',
          ]}
        >
          {item.label}
        </a>
      ))}
      <button id="search-btn-desktop" type="button" class="text-charcoal/40 hover:text-crimson transition-colors" aria-label="Search (Cmd+K)" onclick="window.__openSearch?.()">
        <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="11" cy="11" r="8" stroke-width="2" />
          <path stroke-linecap="round" stroke-width="2" d="m21 21-4.35-4.35" />
        </svg>
      </button>
    </div>
    <!-- Mobile buttons -->
    <div class="flex items-center gap-1 sm:hidden">
      <button id="search-btn-mobile" type="button" class="p-2 text-charcoal/50 hover:text-crimson transition-colors" aria-label="Search" onclick="window.__openSearch?.()">
        <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="11" cy="11" r="8" stroke-width="2" />
          <path stroke-linecap="round" stroke-width="2" d="m21 21-4.35-4.35" />
        </svg>
      </button>
      <button
        id="mobile-menu-btn"
        class="p-2 text-charcoal"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>
  <!-- Mobile menu -->
  <div id="mobile-menu" class="sm:hidden border-t border-charcoal/10 bg-parchment px-4 transition-all duration-200 max-h-0 overflow-hidden">
    {navItems.map((item) => (
      <a
        href={item.href}
        class:list={[
          'block py-2 text-sm font-medium transition-colors',
          pathname.startsWith(item.href)
            ? 'text-crimson'
            : 'text-charcoal/70',
        ]}
      >
        {item.label}
      </a>
    ))}
  </div>
</header>

<script>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    const menu = document.getElementById('mobile-menu');
    const btn = document.getElementById('mobile-menu-btn');
    const isOpen = menu?.classList.contains('max-h-48');
    menu?.classList.toggle('max-h-0', isOpen);
    menu?.classList.toggle('max-h-48', !isOpen);
    menu?.classList.toggle('py-3', !isOpen);
    btn?.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
  });
</script>
