---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
}

const { title, description, ogImage, ogType } = Astro.props;
---

<BaseLayout title={title} description={description} ogImage={ogImage} ogType={ogType}>
  <slot name="head" slot="head" />
  <article class="max-w-[720px] mx-auto px-4 py-12">
    <slot />
  </article>
</BaseLayout>
